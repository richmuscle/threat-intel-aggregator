# ─────────────────────────────────────────────────────────────
#  Threat Intel Aggregator — Environment Configuration
#  Copy to .env and fill in your keys before running.
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────
# Anthropic — powers correlation and report coordinator agents
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Recommended ───────────────────────────────────────────────
# NVD — unauthenticated clients are capped at 5 req/30s and return silent
# 403/empty responses once the budget is exhausted. A free API key raises
# the limit to 50 req/30s and makes cve_scraper reliable.
# Register at: https://nvd.nist.gov/developers/request-an-api-key
# (Usually issued immediately; check your email for the activation link.)
NVD_API_KEY=

# AlienVault OTX — threat pulse + IOC feeds
# Register at: https://otx.alienvault.com
OTX_API_KEY=

# AbuseIPDB — malicious IP blocklist
# Register at: https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=

# ── Optional ──────────────────────────────────────────────────
# GreyNoise — internet scanner / noise data (paid for GNQL)
GREYNOISE_API_KEY=

# ── Swarm tuning ──────────────────────────────────────────────
CVE_DAYS_BACK=7
ATTACK_PLATFORM=Windows
# LLM model for supervisor/correlation/reflection agents. Swap to a Sonnet
# id (e.g. claude-sonnet-4-5) for lower per-run cost.
LLM_MODEL=claude-opus-4-20250514

# ── API server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# FastAPI auth — REQUIRED. The server refuses to start unless either:
#   (a) TIA_API_KEY is set, OR
#   (b) TIA_AUTH_MODE=disabled is set (explicit dev opt-out; logs an ERROR
#       at startup; never use in production).
# Loopback binds are NOT exempt — the contract is the same on every host.
TIA_API_KEY=
# TIA_AUTH_MODE — leave blank in production (auth required). Set to
# `disabled` only in local dev to bypass the gate. Any other value is treated
# as blank and will cause startup to fail if TIA_API_KEY is also unset.
TIA_AUTH_MODE=
# Comma-separated CORS origins. Wildcards (`*`) are stripped. Default is
# localhost only. Set explicitly for any front-end that isn't same-origin.
TIA_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Logging ───────────────────────────────────────────────────
LOG_FORMAT=console
LOG_LEVEL=INFO

# ── SIEM integrations (used by src/integrations/) ──────────────────────────
ELASTIC_PASSWORD=                    # same as ~/dev/floorp/soc-stack/.env
ES_URL=https://127.0.0.1:9201
ES_CA_CERT=/home/richmuscle/dev/floorp/soc-stack/certs/soc-internal-ca.crt
PUSHGATEWAY_URL=http://127.0.0.1:9091
